{
  "name": "atai-ai",
  "version": "1.0.0",
  "description": "CLI workflow tool for frontend Monorepo with apps/* structure — context generation, rule verification, fix suggestions, rules health check, and Figma bitmap compression",
  "type": "module",
  "main": "./dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "atai-ai": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "sharp": "^0.33.5",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
